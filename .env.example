# =============================================================================
# Polymarket BTC 15-Min Bot — Environment Configuration
# =============================================================================

# --- Polymarket Credentials ---
# SECURITY NOTE: For production/live trading, use a secrets manager instead of
# this .env file. Recommended options:
#   - AWS Secrets Manager / SSM Parameter Store
#   - HashiCorp Vault
#   - Docker Secrets
#   - GCP Secret Manager
# The bot will log a warning at startup if it detects credentials in a .env file.
#
# Your Polygon wallet private key (starts with 0x)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Polymarket proxy/safe wallet address
POLYMARKET_PROXY_ADDRESS=0xYOUR_PROXY_ADDRESS_HERE
# CLOB API credentials (generate via py-clob-client)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Trading Parameters ---
# Maximum USD per trade (start small!)
MAX_TRADE_SIZE=1.00
# Maximum daily loss before bot stops trading (USD)
DAILY_LOSS_LIMIT=10.00
# Maximum number of trades per hour
MAX_TRADES_PER_HOUR=8
# Strategy: "momentum", "fusion", "arbitrage", "all"
STRATEGY=all

# --- Momentum Strategy ---
# Seconds before window close to enter (10-60 recommended)
ENTRY_SECONDS_BEFORE_CLOSE=30
# Minimum BTC delta (%) to trigger a momentum trade
MIN_DELTA_THRESHOLD=0.02
# Maximum token price to buy (above this, edge is gone)
MAX_TOKEN_PRICE=0.85

# --- Arbitrage Strategy ---
# Maximum combined price to trigger arb (must be < 1.0)
ARB_THRESHOLD=0.995
# Shares to buy per arb trade
ARB_SHARES=10

# --- Fusion Strategy ---
# Signal weights (must sum to 1.0)
WEIGHT_DELTA=0.50
WEIGHT_ORDERBOOK=0.20
WEIGHT_VOLATILITY=0.15
WEIGHT_MOMENTUM=0.15
# Minimum fused confidence to trade (0.0 - 1.0)
MIN_FUSION_CONFIDENCE=0.55

# --- Risk Management ---
STOP_LOSS_PCT=0.30
TAKE_PROFIT_PCT=0.20
# Cooldown seconds after a losing trade
LOSS_COOLDOWN_SECONDS=120

# --- Paper Trading ---
# Simulated slippage percentage (0.0 = perfect fills, 0.5 = up to 0.5% adverse slippage)
PAPER_SLIPPAGE_PCT=0.5

# --- Data Sources ---
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_1m
BINANCE_REST_URL=https://api.binance.com/api/v3
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
#To find a Telegram bot chat ID, use the
#@RawDataBot or @get_id_bot by starting a chat with them, or use the Telegram API by visiting https://api.telegram.org/bot<YourBotToken>/getUpdates to find it in the chat object. 
#For group IDs, add the bot to the group, send a message, and check the API, 
#ensuring to use the prefix

# Alert levels: "all", "trades_only", "errors_only"
TELEGRAM_ALERT_LEVEL=all

# Enable active trading
ACTIVE_TRADING_ENABLED=true

# Allow buying before the normal T-30s entry window
EARLY_ENTRY_ENABLED=true
EARLY_ENTRY_MIN_CONFIDENCE=0.75     # Need 75%+ confidence for early entry
EARLY_ENTRY_SECONDS_BEFORE_CLOSE=300 # Can enter as early as T-5min

# Exit thresholds (absolute price offsets)
TAKE_PROFIT_THRESHOLD=0.10   # Sell when token price rises $0.10 from entry
STOP_LOSS_THRESHOLD=0.08     # Sell when token price drops $0.08 from entry

# Position limits
MAX_OPEN_POSITIONS=2          # Max concurrent positions
POSITION_MONITOR_INTERVAL=3   # Check positions every 3s
MIN_SELL_SECONDS_BEFORE_CLOSE=10  # Don't sell within 10s of close

# --- Monitoring ---
PROMETHEUS_PORT=8000
GRAFANA_PORT=3000

# --- General ---
LOG_LEVEL=INFO
# "live" or "paper"
TRADING_MODE=paper

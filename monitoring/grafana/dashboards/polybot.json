              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "title": "BTC Price (live)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "polybot_btc_price_usd",

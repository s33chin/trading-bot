          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "transparent", "value": 0 },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "title": "Token Prices",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "polybot_up_ask_price",
          "legendFormat": "UP Ask",
          "refId": "A"
        },
        {
          "expr": "polybot_down_ask_price",
          "legendFormat": "DOWN Ask",
          "refId": "B"
